{
  "name": "py_nexus-db",
  "version": "1.0.0",
  "private": true,
  "description": "PostgreSQL + Prisma database setup for Py Nexus",
  "scripts": {
    "prisma:generate": "prisma generate --schema=../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../prisma/schema.prisma",
    "prisma:seed": "prisma db seed --schema=../prisma/schema.prisma",
    "build": "prisma generate --schema=../prisma/schema.prisma",
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "test": "jest"
  },
  "prisma": {
    "seed": "node ../prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.1",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "prisma": "^6.6.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "jest": "^30.4.2"
  }
}
