# Connection string for PostgreSQL database
DATABASE_URL="postgresql://username:password@localhost:5432/py_nexus?schema=public"

# Cryptographic token signing secret
JWT_SECRET="py_nexus_secret_key_development_only"

# Target port for API engine
PORT=5000

# Server execution environment (development/production)
NODE_ENV="development"

# API access key for Gemini Neural AI Copilot
GEMINI_API_KEY=""
