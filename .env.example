# ==============================================================================
# PY NEXUS — MASTER ENVIRONMENT VARIABLE CONFIGURATION TEMPLATE (.env.example)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. BACKEND SERVICE SETTINGS (backend/.env)
# ------------------------------------------------------------------------------

# PostgreSQL connection string URL schema:
# postgresql://<db_user>:<db_password>@<db_host>:<db_port>/<db_name>?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/py_nexus?schema=public"

# Cryptographically secure random JWT signing key (Min 256-bit recommended)
JWT_SECRET="your_secure_jwt_random_signing_key_here"

# Port on which the Express server listens for API requests
PORT=5000

# Server environment mode (development / production)
NODE_ENV="development"

# Google Gemini API Access Key (Required for auto-grading & insights)
GEMINI_API_KEY="your_gemini_api_key_here"

# Allowed client origin (for CORS configuration)
FRONTEND_URL="http://localhost:5173"


# ------------------------------------------------------------------------------
# 2. FRONTEND CLIENT SETTINGS (frontend/.env)
# ------------------------------------------------------------------------------

# Target Endpoint pointing to the Backend API Server
VITE_API_URL="http://localhost:5000/api"
